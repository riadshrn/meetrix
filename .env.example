# ── Clés API obligatoires ─────────────────────────────────────────────────────

# Groq — transcription Whisper large-v3-turbo (gratuit, ~20 req/min)
# Obtenir une clé : https://console.groq.com/
GROQ_API_KEY=gsk_...

# Mistral — génération comptes rendus, résumés, Q&A
# Obtenir une clé : https://console.mistral.ai/
MISTRAL_API_KEY=sk-...

# ── Configuration optionnelle ──────────────────────────────────────────────────

# URL du backend vue par le frontend (défaut : http://localhost:8000)
# BACKEND_URL=http://localhost:8000

# Niveau de log : DEBUG | INFO | WARNING | ERROR (défaut : INFO)
LOG_LEVEL=INFO
